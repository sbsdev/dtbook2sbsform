<?xml version="1.0" encoding="UTF-8"?>
<x:description xmlns:x="http://www.jenitennison.com/xslt/xspec"
               xmlns:dtb="http://www.daisy.org/z3986/2005/dtbook/"
               xmlns:brl="http://www.daisy.org/z3986/2009/braille/"
               stylesheet="../../../xsl/dtbook2sbsform.xsl">
   <x:scenario label="Plain link">
      <x:param name="contraction" select="2"/>
      <x:context>
        <dtb:a xml:lang="de" href="www.foo.ch">foo</dtb:a>
      </x:context>
      <x:expect label="result">FOO</x:expect>
   </x:scenario>
   <x:scenario label="External link">
      <x:param name="contraction" select="2"/>
      <x:context>
        <dtb:a xml:lang="de" href="www.foo.ch"
                external="true">foo</dtb:a>
      </x:context>
      <x:expect label="result">FOO</x:expect>
   </x:scenario>
   <x:scenario label="External email link">
      <x:param name="contraction" select="2"/>
      <x:context>
        <dtb:a xml:lang="de"
                href="mailto:info@sbs.ch"
                external="true">Kontakt</dtb:a>
      </x:context>
      <x:expect label="result">KONTAKT</x:expect>
   </x:scenario>
   <x:scenario label="External email link mixed">
      <x:param name="contraction" select="2"/>
      <x:context>
        <dtb:a xml:lang="de"
                href="mailto:info@sbs.ch"
                external="true">Kontakt <brl:computer>peter34@gmx.net</brl:computer>
         </dtb:a>
      </x:context>
      <x:expect label="result">KONTAKT '$PETER34"@GMX.NET</x:expect>
   </x:scenario>
   <x:scenario label="Internal link">
      <x:param name="contraction" select="2"/>
      <x:context>
	        <stub xml:lang="de">
            <dtb:a id="foo"/>
            <dtb:a href="#foo">foo</dtb:a>
	        </stub>
      </x:context>
      <x:expect label="result">FOO</x:expect>
   </x:scenario>
   <x:scenario label="Internal pageref link">
      <x:param name="contraction" select="2"/>
      <x:context>
	        <stub xml:lang="de">
            <dtb:a id="foo"/>
            <dtb:a href="#foo" class="pageref">foo</dtb:a>
	        </stub>
      </x:context>
      <x:expect label="result">FOO</x:expect>
   </x:scenario>
   <x:scenario label="External link using computer braille">
      <x:param name="contraction" select="2"/>
      <x:context>
	        <stub xml:lang="de">
            <dtb:a href="http://www.sbs.ch">
               <brl:computer>www.sbs.ch</brl:computer>
            </dtb:a>
	        </stub>
      </x:context>
      <x:expect label="result">'$WWW.SBS.CH</x:expect>
   </x:scenario>
   <x:scenario label="External link using computer braille">
      <x:param name="contraction" select="2"/>
      <x:context>
	        <stub xml:lang="de">
            <dtb:a href="http://www.e-text.ch">
               <brl:computer>www.e-text.ch</brl:computer>
            </dtb:a>
	        </stub>
      </x:context>
      <x:expect label="result">'$WWW.E-TEXT.CH</x:expect>
   </x:scenario>
   <x:scenario label="External link with params using computer braille">
      <x:param name="contraction" select="2"/>
      <x:context>
	        <stub xml:lang="de">
            <dtb:a href="http://www.google-test.ch/test?=:;+%#$">
               <brl:computer>http://www.google-test.ch/test?=:;+%#$</brl:computer>
            </dtb:a>
	        </stub>
      </x:context>
      <x:expect label="result">'$HTTP://WWW.GOOGLE-TEST.CH/TEST?=:;+%#$$</x:expect>
   </x:scenario>
   <x:scenario label="External link with numbers using computer braille">
      <x:param name="contraction" select="2"/>
      <x:context>
	        <stub xml:lang="de">
            <dtb:a href="mailto:peter34@gmx.net">
               <brl:computer>peter34@gmx.net</brl:computer>
            </dtb:a>
	        </stub>
      </x:context>
      <x:expect label="result">'$PETER34"@GMX.NET</x:expect>
   </x:scenario>
   <x:scenario label="External email link using computer braille">
      <x:param name="contraction" select="2"/>
      <x:context>
	        <stub xml:lang="de">
            <dtb:a href="mailto:info@sbs.ch">
               <brl:computer>mailto:info@sbs.ch</brl:computer>
            </dtb:a>
	        </stub>
      </x:context>
      <x:expect label="result">'$MAILTO:INFO"@SBS.CH</x:expect>
   </x:scenario>
   <x:scenario label="External email link using computer braille">
      <x:param name="contraction" select="2"/>
      <x:context>
	        <stub xml:lang="de">
            <dtb:a href="mailto:meier_alex@ubs.com">
               <brl:computer>meier_alex@ubs.com</brl:computer>
            </dtb:a>
	        </stub>
      </x:context>
      <x:expect label="result">'$MEIER"_ALEX"@UBS.COM</x:expect>
   </x:scenario>
</x:description>