<?xml version="1.0" encoding="UTF-8"?>
<x:description xmlns:x="http://www.jenitennison.com/xslt/xspec"
               xmlns:dtb="http://www.daisy.org/z3986/2005/dtbook/"
               xmlns:brl="http://www.daisy.org/z3986/2009/braille/"
               stylesheet="../../../xsl/dtbook2sbsform.xsl">
   <x:scenario label="address">
      <x:param name="contraction" select="2"/>
      <x:context>
        <dtb:address xmlns:utfx="http://utfx.org/test-definition" xml:lang="de">Foo</dtb:address>
      </x:context>
      <x:expect label="result">
xxx Was originally a dtb:address

y LINEGRb
 FOO
y LINEGRe
</x:expect>
   </x:scenario>
   <x:scenario label="address with lines">
      <x:param name="contraction" select="2"/>
      <x:context>
        <dtb:address xmlns:utfx="http://utfx.org/test-definition" xml:lang="de">
	           <dtb:line>Bar</dtb:line>
	           <dtb:line>Baz</dtb:line>
	        </dtb:address>
      </x:context>
      <x:expect label="result">
xxx Was originally a dtb:address

y LINEGRb
 
y LINEb
 BAR
y LINEe

y LINEb
 BAZ
y LINEe

y LINEGRe
</x:expect>
   </x:scenario>
</x:description>