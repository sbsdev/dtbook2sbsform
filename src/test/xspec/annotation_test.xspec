<?xml version="1.0" encoding="UTF-8"?>
<x:description xmlns:x="http://www.jenitennison.com/xslt/xspec"
               xmlns:dtb="http://www.daisy.org/z3986/2005/dtbook/"
               xmlns:brl="http://www.daisy.org/z3986/2009/braille/"
               stylesheet="../../../xsl/dtbook2sbsform.xsl">
   <x:scenario label="annotation with standard placement and automatic numbering">
      <x:param name="contraction" select="2"/>
      <x:param name="footnote_placement" select="'standard'"/>
      <x:context>
	        <stub xml:lang="de">Blah <dtb:annoref idref="#annotation1">hihi</dtb:annoref> 
            <dtb:annoref idref="#annotation2">haha</dtb:annoref> blah</stub>
      </x:context>
      <x:expect label="result">BLAH HIHI'*#A
* 
 HAHA'*#B
* 
  BLAH</x:expect>
   </x:scenario>
   <x:scenario label="annotation with standard placement and automatic numbering">
      <x:param name="contraction" select="2"/>
      <x:param name="footnote_placement" select="'standard'"/>
      <x:context>
	        <stub xml:lang="de">
	           <dtb:annoref idref="#annotation1">Foo</dtb:annoref> Bar
	  <dtb:annoref idref="#annotation2">Baz</dtb:annoref> Baz
	</stub>
      </x:context>
      <x:expect label="result">FOO'*#A
* 
  BAR BAZ'*#B
* 
  BAZ </x:expect>
   </x:scenario>
   <x:scenario label="annotation with end-vol placement">
      <x:param name="contraction" select="2"/>
      <x:param name="footnote_placement" select="'end-vol'"/>
      <x:context>
	        <stub xml:lang="de">Hi Ha <dtb:annoref idref="#annotation1">Ho</dtb:annoref>
	           <dtb:annoref idref="#annotation2"/>
	           <brl:volume brl:grade="2"/>Foo Bar Baz <dtb:annoref idref="#annotation3"/>
	           <dtb:annoref idref="#annotation4"/>
	           <brl:volume brl:grade="2"/>
	           <dtb:annotation id="annotation1">
	              <dtb:p>This is a test</dtb:p>
	           </dtb:annotation>
	           <dtb:annotation id="annotation2">
	              <dtb:p>This is another test</dtb:p>
	           </dtb:annotation>
	           <dtb:annotation id="annotation3">
	              <dtb:p>This is a test</dtb:p>
	           </dtb:annotation>
	           <dtb:annotation id="annotation4">
	              <dtb:p>This is another test</dtb:p>
	           </dtb:annotation>
         </stub>
      </x:context>
      <x:expect label="result">HI HA HO'*#A
* 
 '*#B
* 
 
y Notes

a 
 #A THIS IS 'A TE]
a 
 #B THIS IS +OTH7 TE]
y EndVol
y BrlVol
FOO BAR BAZ '*#C
* 
 '*#D
* 
 
y Notes

a 
 #C THIS IS 'A TE]
a 
 #D THIS IS +OTH7 TE]
y EndVol
y BrlVol
</x:expect>
   </x:scenario>
   <x:scenario label="annotation in bodymatter with end-vol placement">
      <x:param name="contraction" select="2"/>
      <x:param name="footnote_placement" select="'end-vol'"/>
      <x:context>
	        <dtb:bodymatter xml:lang="de">
	           <dtb:p>Hi <dtb:annoref idref="#annotation1">Ha</dtb:annoref> 
	              <dtb:annoref idref="#annotation2">Ho</dtb:annoref>
	              <brl:volume brl:grade="2"/>Foo <dtb:annoref idref="#annotation3">Bar</dtb:annoref>
	              <dtb:annoref idref="#annotation4">Baz</dtb:annoref>
	              <brl:volume brl:grade="2"/>
	              <dtb:annotation id="annotation1">
	                 <dtb:p>This is a test</dtb:p>
	              </dtb:annotation>
	              <dtb:annotation id="annotation2">
	                 <dtb:p>This is another test</dtb:p>
	              </dtb:annotation>
	              <dtb:annotation id="annotation3">
	                 <dtb:p>This is a test</dtb:p>
	              </dtb:annotation>
	              <dtb:annotation id="annotation4">
	                 <dtb:p>This is another test</dtb:p>
	              </dtb:annotation>
            </dtb:p>
	           <dtb:pagenum>1</dtb:pagenum>
	        </dtb:bodymatter>
      </x:context>
      <x:expect label="result">
y BODYb
i j=1

y P
 HI HA'*#A
* 
  HO'*#B
* 
  
y Notes

a 
 #A THIS IS 'A TE]
a 
 #B THIS IS +OTH7 TE]
y EndVol
y BrlVol
FOO BAR'*#C
* 
  BAZ'*#D
* 
  
y Notes

a 
 #C THIS IS 'A TE]
a 
 #D THIS IS +OTH7 TE]
y EndVol
y BrlVol
    
j 1
 

y BODYe
</x:expect>
   </x:scenario>
   <x:scenario label="annotation inside h1 (http://redmine.sbszh.ch/issues/1260)">
      <x:param name="contraction" select="2"/>
      <x:param name="footnote_placement" select="'standard'"/>
      <x:context>
	        <dtb:h1 xml:lang="de">Sein und nicht <dtb:annoref idref="#fn1">sein</dtb:annoref>
         </dtb:h1>
      </x:context>
      <x:expect label="result">
y H1
 9 U N 9'*#A
* 
 
</x:expect>
   </x:scenario>
   <x:scenario label="annotation followed by ',' http://redmine.sbszh.ch/issues/1264">
      <x:param name="contraction" select="2"/>
      <x:param name="footnote_placement" select="'standard'"/>
      <x:context>
	        <dtb:p xml:lang="de">Hier die <dtb:annoref idref="#fn1">Fussnote</dtb:annoref>, vor einem Komma</dtb:p>
      </x:context>
      <x:expect label="result">
y P
 HR 0 FU^NO('*#A,
* 
 ? 6[ KXA</x:expect>
   </x:scenario>
   <x:scenario label="annotation followed by '!' http://redmine.sbszh.ch/issues/1264">
      <x:param name="contraction" select="2"/>
      <x:param name="footnote_placement" select="'standard'"/>
      <x:context>
	        <dtb:p xml:lang="de">Hier die <dtb:annoref idref="#fn1">Fussnote</dtb:annoref>! vor einem</dtb:p>
      </x:context>
      <x:expect label="result">
y P
 HR 0 FU^NO('*#A'+
* 
 ? 6[</x:expect>
   </x:scenario>
   <x:scenario label="annotation followed by '?' http://redmine.sbszh.ch/issues/1264">
      <x:param name="contraction" select="2"/>
      <x:param name="footnote_placement" select="'standard'"/>
      <x:context>
	        <dtb:p xml:lang="de">Hier die <dtb:annoref idref="#fn1">Fussnote</dtb:annoref>? vor einem</dtb:p>
      </x:context>
      <x:expect label="result">
y P
 HR 0 FU^NO('*#A'?
* 
 ? 6[</x:expect>
   </x:scenario>
   <x:scenario label="annotation followed by '(' http://redmine.sbszh.ch/issues/1264">
      <x:param name="contraction" select="2"/>
      <x:param name="footnote_placement" select="'standard'"/>
      <x:context>
	        <dtb:p xml:lang="de">Hier die <dtb:annoref idref="#fn1">Fussnote</dtb:annoref>( vor einem</dtb:p>
      </x:context>
      <x:expect label="result">
y P
 HR 0 FU^NO('*#A'=
* 
 ? 6[</x:expect>
   </x:scenario>
</x:description>