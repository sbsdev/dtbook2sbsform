<?xml version="1.0" encoding="UTF-8"?>
<x:description xmlns:x="http://www.jenitennison.com/xslt/xspec"
               xmlns:dtb="http://www.daisy.org/z3986/2005/dtbook/"
               xmlns:brl="http://www.daisy.org/z3986/2009/braille/"
               stylesheet="../../../xsl/dtbook2sbsform.xsl">
   <x:scenario label="context across block boundaries Bug #1395 with em before">
      <x:param name="contraction" select="2"/>
      <x:context>
        <stub xml:lang="de">
            <dtb:byline>
               <dtb:em>Tages-­Anzeiger</dtb:em>
            </dtb:byline>
            <dtb:p>Zum Autor</dtb:p>
         </stub>
      </x:context>
      <x:expect label="result">
y BYLINE
 __TAG%-m+Z3G7'.
y P
 ZM 1TOR</x:expect>
   </x:scenario>
   <x:scenario label="context across block boundaries Bug #1395 with em after">
      <x:param name="contraction" select="2"/>
      <x:context>
        <stub xml:lang="de">
            <dtb:byline>Tages-­Anzeiger</dtb:byline>
            <dtb:p>
               <dtb:em>Zum Autor</dtb:em>
            </dtb:p>
         </stub>
      </x:context>
      <x:expect label="result">
y BYLINE
 TAG%-m+Z3G7
y P
 __ZM 1TOR'.</x:expect>
   </x:scenario>
   <x:scenario label="context across block boundaries Bug #1395 with em both">
      <x:param name="contraction" select="2"/>
      <x:context>
        <stub xml:lang="de">
            <dtb:byline>
               <dtb:em>Tages-­Anzeiger</dtb:em>
            </dtb:byline>
            <dtb:p>
               <dtb:em>Zum Autor</dtb:em>
            </dtb:p>
         </stub>
      </x:context>
      <x:expect label="result">
y BYLINE
 __TAG%-m+Z3G7'.
y P
 __ZM 1TOR'.</x:expect>
   </x:scenario>
   <x:scenario label="context across block boundaries Bug #1395">
      <x:param name="contraction" select="2"/>
      <x:context>
        <stub xml:lang="de">
            <dtb:byline>Tages-­Anzeiger</dtb:byline>
            <dtb:p>Zum Autor</dtb:p>
         </stub>
      </x:context>
      <x:expect label="result">
y BYLINE
 TAG%-m+Z3G7
y P
 ZM 1TOR</x:expect>
   </x:scenario>
   <x:scenario label="Context across text nodes ending with punctuation">
      <x:param name="contraction" select="2"/>
      <x:context>
        <stub xml:lang="de">»<dtb:span>Tages-­Anzeiger.</dtb:span>« Zum Autor</stub>
      </x:context>
      <x:expect label="result">(TAG%-m+Z3G7.) ZM 1TOR</x:expect>
   </x:scenario>
   <x:scenario label="Context across block boundaries ending with punctuation">
      <x:param name="contraction" select="2"/>
      <x:context>
        <stub xml:lang="de">»Tages-­Anzeiger.<dtb:p>« Zum Autor</dtb:p>
         </stub>
      </x:context>
      <x:expect label="result">(TAG%-m+Z3G7.
y P
 ) ZM 1TOR</x:expect>
   </x:scenario>
   <x:scenario label="Another weird context problem">
      <x:param name="contraction" select="2"/>
      <x:context>
        <dtb:p xml:lang="de">
            <dtb:em>Mist</dtb:em>, dachte er, <dtb:em>wie komme ich hier raus?</dtb:em>
         </dtb:p>
      </x:context>
      <x:expect label="result">
y P
 _MI], D&lt;( 7, __2 KXE # HR R1S?'.</x:expect>
   </x:scenario>
   <x:scenario label="Text matcher inside block, h1">
      <x:param name="contraction" select="2"/>
      <x:context>
        <dtb:h1 xml:lang="de">
            <dtb:abbr>ABC</dtb:abbr>s</dtb:h1>
      </x:context>
      <x:expect label="result">
y H1
 &gt;ABC'S</x:expect>
   </x:scenario>
   <x:scenario label="Text matcher inside block, p">
      <x:param name="contraction" select="2"/>
      <x:context>
        <dtb:p xml:lang="de">
            <dtb:abbr>ABC</dtb:abbr>s</dtb:p>
      </x:context>
      <x:expect label="result">
y P
 &gt;ABC'S</x:expect>
   </x:scenario>
   <x:scenario label="Text matcher inside block, bridgehead">
      <x:param name="contraction" select="2"/>
      <x:context>
        <dtb:bridgehead xml:lang="de">
            <dtb:abbr>ABC</dtb:abbr>s</dtb:bridgehead>
      </x:context>
      <x:expect label="result">
y BRIDGE
 &gt;ABC'S</x:expect>
   </x:scenario>
   <x:scenario label="Text matcher inside block, hd">
      <x:param name="contraction" select="2"/>
      <x:context>
        <dtb:hd xml:lang="de">
            <dtb:abbr>ABC</dtb:abbr>s</dtb:hd>
      </x:context>
      <x:expect label="result">
y HD
 &gt;ABC'S</x:expect>
   </x:scenario>
   <x:scenario label="Text matcher inside block, dd and dt">
      <x:param name="contraction" select="2"/>
      <x:context>
        <dtb:dd xml:lang="de">
            <dtb:abbr>ABC</dtb:abbr>s</dtb:dd>
        <dtb:dt xml:lang="de">
            <dtb:abbr>ABC</dtb:abbr>s</dtb:dt>
      </x:context>
      <x:expect label="result">
y DDb
 &gt;ABC'S
y DDe
y DTb
 &gt;ABC'S
y DTe</x:expect>
   </x:scenario>
   <x:scenario label="Text matcher inside block, caption, th and td">
      <x:param name="contraction" select="2"/>
      <x:context>
        <dtb:caption xml:lang="de">
            <dtb:abbr>ABC</dtb:abbr>s</dtb:caption>
      </x:context>
      <x:expect label="result">
y CAPTION
 &gt;ABC'S</x:expect>
   </x:scenario>
   <x:scenario label="Text matcher inside block, th and td">
      <x:param name="contraction" select="2"/>
      <x:context>
        <dtb:th xml:lang="de">
            <dtb:abbr>ABC</dtb:abbr>s</dtb:th>
        <dtb:td xml:lang="de">
            <dtb:abbr>ABC</dtb:abbr>s</dtb:td>
      </x:context>
      <x:expect label="result">&gt;ABC'S&gt;ABC'S</x:expect>
   </x:scenario>

  <!-- Known bug: *-sibling axis cannot see across a <dtb:span> wrapper, so em-at-word-boundary
       detection fails when the em is nested inside a span. -->
  <x:pending label="bug #1395: em inside span not detected as word-boundary em (*-sibling limitation)">
    <x:scenario label="context Bug #1395 with em after, inside span">
      <x:param name="contraction" select="2"/>
      <x:context>
        <stub xml:lang="de">Tages<dtb:span><dtb:em>Autor</dtb:em></dtb:span></stub>
      </x:context>
      <x:expect label="result">TAG%'_1TOR</x:expect>
    </x:scenario>
  </x:pending>

</x:description>