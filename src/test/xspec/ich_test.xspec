   <x:scenario label="ich as last word in h1 followed by opening quote in next paragraph should not trigger special ich handling http://redmine.sbszh.ch/issues/2932">
      <x:param name="contraction" select="2"/>
      <x:context>
        <dtb:level1 xml:lang="de">
          <dtb:h1>du und ich</dtb:h1>
          <dtb:p>»bla</dtb:p>
        </dtb:level1>
      </x:context>
      <x:expect label="h1 renders ich as # not I4">
y LEVEL1b
.xNOPAGENUM

y H1
 DU U #

y P
 (BLA
y LEVEL1e</x:expect>
   </x:scenario>
