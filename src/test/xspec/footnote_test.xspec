<?xml version="1.0" encoding="UTF-8"?>
<x:description xmlns:x="http://www.jenitennison.com/xslt/xspec"
               xmlns:dtb="http://www.daisy.org/z3986/2005/dtbook/"
               xmlns:brl="http://www.daisy.org/z3986/2009/braille/"
               stylesheet="../../../xsl/dtbook2sbsform.xsl">
   <x:scenario label="footnote with standard placement and automatic numbering">
      <x:param name="contraction" select="2"/>
      <x:param name="footnote_placement" select="'standard'"/>
      <x:context>
	        <stub xml:lang="de">Foo<dtb:noteref idref="#footnote1">a</dtb:noteref>	Bar<dtb:noteref idref="#footnote2">b</dtb:noteref> Baz</stub>
      </x:context>
      <x:expect label="result">FOO'*#A
* 
  BAR'*#B
* 
  BAZ</x:expect>
   </x:scenario>
   <x:scenario label="footnote with end-vol placement">
      <x:param name="contraction" select="2"/>
      <x:param name="footnote_placement" select="'end-vol'"/>
      <x:context>
	        <stub xml:lang="de">Hi Ha Ho <dtb:noteref idref="#footnote1"/>
	           <dtb:noteref idref="#footnote2"/>
	           <brl:volume brl:grade="2"/>Foo Bar Baz <dtb:noteref idref="#footnote3"/>
	           <dtb:noteref idref="#footnote4"/>
	           <brl:volume brl:grade="2"/>
	           <dtb:note id="footnote1">
	              <dtb:p>This is a test</dtb:p>
	           </dtb:note>
	           <dtb:note id="footnote2">
	              <dtb:p>This is another test</dtb:p>
	           </dtb:note>
	           <dtb:note id="footnote3">
	              <dtb:p>This is a test</dtb:p>
	           </dtb:note>
	           <dtb:note id="footnote4">
	              <dtb:p>This is another test</dtb:p>
	           </dtb:note>
         </stub>
      </x:context>
      <x:expect label="result">HI HA HO '*#A
* 
 '*#B
* 
 
y Notes

a 
 #A THIS IS 'A TE]
a 
 #B THIS IS +OTH7 TE]
y EndVol
y BrlVol
FOO BAR BAZ '*#C
* 
 '*#D
* 
 
y Notes

a 
 #C THIS IS 'A TE]
a 
 #D THIS IS +OTH7 TE]
y EndVol
y BrlVol
</x:expect>
   </x:scenario>
   <x:scenario label="footnote inside h1 (http://redmine.sbszh.ch/issues/1260)">
      <x:param name="contraction" select="2"/>
      <x:param name="footnote_placement" select="'standard'"/>
      <x:context>
	        <dtb:h1 xml:lang="de">Sein und nicht sein<dtb:noteref idref="#fn1">1</dtb:noteref>
         </dtb:h1>
      </x:context>
      <x:expect label="result">
y H1
 9 U N 9'*#A
* 
 
</x:expect>
   </x:scenario>
   <x:scenario label="footnote followed by ',' http://redmine.sbszh.ch/issues/1264">
      <x:param name="contraction" select="2"/>
      <x:param name="footnote_placement" select="'standard'"/>
      <x:context>
	        <dtb:p xml:lang="de">Hier die Fussnote<dtb:noteref idref="#fn1">1</dtb:noteref>, vor einem Komma</dtb:p>
      </x:context>
      <x:expect label="result">
y P
 HR 0 FU^NO('*#A,
* 
 ? 6[ KXA</x:expect>
   </x:scenario>
