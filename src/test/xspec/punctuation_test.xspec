<?xml version="1.0" encoding="UTF-8"?>
<x:description xmlns:x="http://www.jenitennison.com/xslt/xspec"
               xmlns:dtb="http://www.daisy.org/z3986/2005/dtbook/"
               xmlns:brl="http://www.daisy.org/z3986/2009/braille/"
               stylesheet="../../../xsl/dtbook2sbsform.xsl">
   <x:scenario label="punctuation after numbers">
      <x:param name="contraction" select="2"/>
      <x:context>
        <dtb:p xml:lang="de"> 
            <dtb:em>2</dtb:em>? <dtb:em>2</dtb:em>! <dtb:em>2</dtb:em>; (<dtb:em>2</dtb:em>) »<dtb:em>2</dtb:em>« </dtb:p>
      </x:context>
      <x:expect label="result">
y P
  _#B'? _#B'+ _#B'; =_#B'= (_#B') </x:expect>
   </x:scenario>
   <x:scenario label="punctuation after numbers">
      <x:param name="contraction" select="2"/>
      <x:context>
        <dtb:p>»Am 10?«</dtb:p>
        <dtb:p>»Am 10?«</dtb:p>
      </x:context>
      <x:expect label="result">
y P
 (AM #AJ'?)
y P
 (AM #AJ'?)</x:expect>
   </x:scenario>
   <x:scenario label="punctuation after numbers in a previous paragraph">
      <x:param name="contraction" select="2"/>
      <x:context>
        <stub xml:lang="de">
            <dtb:p>20 Minuten <brl:date value="2012-10-16">16.10.2012</brl:date>
            </dtb:p>
            <dtb:p>(blo)</dtb:p>
        </stub>
      </x:context>
      <x:expect label="result">
y P
 #BJ M*UTC #,+AJ#BJAB
y P
 =BLO=</x:expect>
   </x:scenario>
   <x:scenario label="punctuation after ordinals">
      <x:param name="contraction" select="2"/>
      <x:context>
        <dtb:p xml:lang="de"> 
            <brl:num role="ordinal">2.</brl:num>? <brl:num role="ordinal">2.</brl:num>! <brl:num role="ordinal">2.</brl:num>; (<brl:num role="ordinal">2.</brl:num>) »<brl:num role="ordinal">2.</brl:num>« </dtb:p>
      </x:context>
      <x:expect label="result">
y P
  #;'? #;'+ #;'; =#;'= (#;') </x:expect>
   </x:scenario>
   <x:scenario label="punctuation after ordinals">
      <x:param name="contraction" select="2"/>
      <x:context>
        <dtb:p>»Am <brl:num role="ordinal">10.</brl:num>?«</dtb:p>
        <dtb:p>»Am <brl:num role="ordinal">10.</brl:num>?«</dtb:p>
      </x:context>
      <x:expect label="result">
y P
 (AM #,)'?)
y P
 (AM #,)'?)</x:expect>
   </x:scenario>
</x:description>