<?xml version="1.0" encoding="UTF-8"?>
<x:description xmlns:x="http://www.jenitennison.com/xslt/xspec"
               xmlns:dtb="http://www.daisy.org/z3986/2005/dtbook/"
               xmlns:brl="http://www.daisy.org/z3986/2009/braille/"
               stylesheet="../../../xsl/dtbook2sbsform.xsl">
   <x:scenario label="Samp block">
      <x:param name="contraction" select="2"/>
      <x:context>
	        <dtb:level1 xml:lang="de">
            <dtb:samp>Foo</dtb:samp>
	        </dtb:level1>
      </x:context>
      <x:expect label="result">
y LEVEL1b
.xNOPAGENUM

xxx Was originally a dtb:samp
y P
 FOO
y LEVEL1e
</x:expect>
   </x:scenario>
   <x:scenario label="Samp block">
      <x:param name="contraction" select="2"/>
      <x:context>
	        <dtb:div brl:class="foo" xml:lang="de">
            <dtb:samp>Foo</dtb:samp>
	        </dtb:div>
      </x:context>
      <x:expect label="result">
y DIVb_foo

xxx Was originally a dtb:samp
y P
 FOO
y DIVe_foo
</x:expect>
   </x:scenario>
   <x:scenario label="Samp inline (inside p)">
      <x:param name="contraction" select="2"/>
      <x:context>
	        <dtb:p xml:lang="de">Foo <dtb:samp>Bar</dtb:samp> Baz</dtb:p>
      </x:context>
      <x:expect label="result">
y P
 FOO BAR BAZ</x:expect>
   </x:scenario>
   <x:scenario label="Samp inline (inside th)">
      <x:param name="contraction" select="2"/>
      <x:context>
	        <dtb:th xml:lang="de">Foo <dtb:samp>Bar</dtb:samp> Baz</dtb:th>
      </x:context>
      <x:expect label="result">FOO BAR BAZ</x:expect>
   </x:scenario>
   <x:scenario label="Samp inline (inside td)">
      <x:param name="contraction" select="2"/>
      <x:context>
	        <dtb:td xml:lang="de">Foo <dtb:samp>Bar</dtb:samp> Baz</dtb:td>
      </x:context>
      <x:expect label="result">FOO BAR BAZ</x:expect>
   </x:scenario>
   <x:scenario label="Samp inline (inside li)">
      <x:param name="contraction" select="2"/>
      <x:context>
	        <dtb:li xml:lang="de">Foo <dtb:samp>Bar</dtb:samp> Baz</dtb:li>
      </x:context>
      <x:expect label="result">
y LI
 FOO BAR BAZ
</x:expect>
   </x:scenario>
</x:description>