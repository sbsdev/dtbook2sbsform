<?xml version="1.0" encoding="UTF-8"?>
<x:description xmlns:x="http://www.jenitennison.com/xslt/xspec"
               xmlns:dtb="http://www.daisy.org/z3986/2005/dtbook/"
               xmlns:brl="http://www.daisy.org/z3986/2009/braille/"
               stylesheet="../../../xsl/dtbook2sbsform.xsl">
   <x:scenario label="list with brl:class attr">
      <x:context>
        <stub xmlns:utfx="http://utfx.org/test-definition" xml:lang="de">
	           <dtb:list brl:class="foo" type="pl"/>
	           <dtb:list brl:class="foo" type="ul"/>
	           <dtb:list brl:class="foo" type="ol"/>
        </stub>
      </x:context>
      <x:expect label="result">
y PLISTb_foo

y PLISTe_foo

y ULISTb_foo

y ULISTe_foo

y OLISTb_foo

y OLISTe_foo
</x:expect>
   </x:scenario>
   <x:scenario label="li with brl:class attr">
      <x:context>
        <stub xmlns:utfx="http://utfx.org/test-definition" xml:lang="de">
	           <dtb:li brl:class="foo"/>
        </stub>
      </x:context>
      <x:expect label="result">
y LI_foo
 
</x:expect>
   </x:scenario>
   <x:scenario label="Preformatted lists">
      <x:context>
        <stub xmlns:utfx="http://utfx.org/test-definition" xml:lang="de">
	           <dtb:list type="pl">
               <dtb:li>1. bla bla</dtb:li>
               <dtb:li>2. bla bla</dtb:li>
               <dtb:li>3. bla bla
            <dtb:list type="pl">
                     <dtb:li>a) blo blo
                <dtb:list type="pl">
                           <dtb:li>i. ble ble</dtb:li>
                           <dtb:li>ii. ble ble</dtb:li>
                        </dtb:list>
                     </dtb:li>
                     <dtb:li>b) blo blo</dtb:li>
                  </dtb:list>
               </dtb:li>
               <dtb:li>4. bla bla
            <dtb:list type="pl">
                     <dtb:li>a) blo blo
                <dtb:list type="pl">
                           <dtb:li>i. ble ble</dtb:li>
                           <dtb:li>ii. ble ble</dtb:li>
                        </dtb:list>
                     </dtb:li>
                     <dtb:li>b) blo blo</dtb:li>
                  </dtb:list>
               </dtb:li>
               <dtb:li>5. bla bla</dtb:li>
            </dtb:list>
        </stub>
      </x:context>
      <x:expect label="result">
y PLISTb

y LI
 #A. BLA BLA

y LI
 #B. BLA BLA

y LI
 #C. BLA BLA 
y PLISTb

y LI
 'A= BLO BLO 
y PLISTb

y LI
 I. BLE BLE

y LI
 II. BLE BLE

y PLISTe
 

y LI
 'B= BLO BLO

y PLISTe
 

y LI
 #D. BLA BLA 
y PLISTb

y LI
 'A= BLO BLO 
y PLISTb

y LI
 I. BLE BLE

y LI
 II. BLE BLE

y PLISTe
 

y LI
 'B= BLO BLO

y PLISTe
 

y LI
 #E. BLA BLA

y PLISTe
</x:expect>
   </x:scenario>
   <x:scenario label="Unordered lists">
      <x:context>
        <stub xmlns:utfx="http://utfx.org/test-definition" xml:lang="de">
	           <dtb:list type="ul">
               <dtb:li>bla bla</dtb:li>
               <dtb:li>bla bla</dtb:li>
               <dtb:li>bla bla
            <dtb:list type="ul">
                     <dtb:li>blo blo
                <dtb:list type="ul">
                           <dtb:li>ble ble</dtb:li>
                           <dtb:li>ble ble</dtb:li>
                        </dtb:list>
                     </dtb:li>
                     <dtb:li>blo blo</dtb:li>
                  </dtb:list>
               </dtb:li>
               <dtb:li>bla bla
            <dtb:list type="ul">
                     <dtb:li>blo blo
                <dtb:list type="ul">
                           <dtb:li>ble ble</dtb:li>
                           <dtb:li>ble ble</dtb:li>
                        </dtb:list>
                     </dtb:li>
                     <dtb:li>blo blo</dtb:li>
                  </dtb:list>
               </dtb:li>
               <dtb:li>bla bla</dtb:li>
            </dtb:list>
        </stub>
      </x:context>
      <x:expect label="result">
y ULISTb

y LI
 '- BLA BLA

y LI
 '- BLA BLA

y LI
 '- BLA BLA 
y ULISTb

y LI
 !- BLO BLO 
y ULISTb

y LI
 '- BLE BLE

y LI
 '- BLE BLE

y ULISTe
 

y LI
 !- BLO BLO

y ULISTe
 

y LI
 '- BLA BLA 
y ULISTb

y LI
 !- BLO BLO 
y ULISTb

y LI
 '- BLE BLE

y LI
 '- BLE BLE

y ULISTe
 

y LI
 !- BLO BLO

y ULISTe
 

y LI
 '- BLA BLA

y ULISTe
</x:expect>
   </x:scenario>
