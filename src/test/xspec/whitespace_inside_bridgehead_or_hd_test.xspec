<?xml version="1.0" encoding="UTF-8"?>
<x:description xmlns:x="http://www.jenitennison.com/xslt/xspec"
               xmlns:dtb="http://www.daisy.org/z3986/2005/dtbook/"
               xmlns:brl="http://www.daisy.org/z3986/2009/braille/"
               stylesheet="../../../xsl/dtbook2sbsform.xsl">
   <x:scenario label="Whitespace between brl:date und brl:time inside bridgehead is removed, http://redmine.sbszh.ch/issues/2625">
      <x:param name="contraction" select="2"/>
      <x:context>
	        <dtb:bridgehead xml:lang="de">
            <brl:date value="1945-01-26">26.01.1945</brl:date> 
            <brl:time value="23:30">23:30</brl:time>
         </dtb:bridgehead>
      </x:context>
      <x:expect label="result">
y BRIDGE
 #;+JA#AIDE #BC':#CJ</x:expect>
   </x:scenario>
   <x:scenario label="Whitespace between brl:date und brl:time inside hd is removed, http://redmine.sbszh.ch/issues/2625">
      <x:param name="contraction" select="2"/>
      <x:context>
	        <dtb:hd xml:lang="de">
            <brl:date value="1945-01-26">26.01.1945</brl:date> 
            <brl:time value="23:30">23:30</brl:time>
         </dtb:hd>
      </x:context>
      <x:expect label="result">
y HD
 #;+JA#AIDE #BC':#CJ</x:expect>
   </x:scenario>
</x:description>