<?xml version="1.0" encoding="UTF-8"?>
<x:description xmlns:x="http://www.jenitennison.com/xslt/xspec"
               xmlns:dtb="http://www.daisy.org/z3986/2005/dtbook/"
               xmlns:brl="http://www.daisy.org/z3986/2009/braille/"
               stylesheet="../../../xsl/dtbook2sbsform.xsl">
   <x:scenario label="dfn">
      <x:param name="contraction" select="2"/>
      <x:context>
        <dtb:dfn xmlns:utfx="http://utfx.org/test-definition" xml:lang="de">Foo</dtb:dfn>
      </x:context>
      <x:expect label="result">
xxx Was originally a dtb:dfn
 _FOO</x:expect>
   </x:scenario>
   <x:scenario label="Multiword dfn">
      <x:param name="contraction" select="2"/>
      <x:context>
        <dtb:dfn xmlns:utfx="http://utfx.org/test-definition" xml:lang="de">Foo Bar</dtb:dfn>
      </x:context>
      <x:expect label="result">
xxx Was originally a dtb:dfn
 __FOO BAR'.</x:expect>
   </x:scenario>
   <x:scenario label="Multiword dfn">
      <x:param name="contraction" select="2"/>
      <x:context>
        <dtb:dfn xmlns:utfx="http://utfx.org/test-definition" xml:lang="de">Foo Bar Baz</dtb:dfn>
      </x:context>
      <x:expect label="result">
xxx Was originally a dtb:dfn
 __FOO BAR BAZ'.</x:expect>
   </x:scenario>
   <x:scenario label="dfn with context">
      <x:param name="contraction" select="2"/>
      <x:context>
	        <dtb:p xmlns:utfx="http://utfx.org/test-definition" xml:lang="de">Haha <dtb:dfn xml:lang="de">Foo Bar Baz</dtb:dfn>
         </dtb:p>
      </x:context>
      <x:expect label="result">
y P
 HAHA 
xxx Was originally a dtb:dfn
 __FOO BAR BAZ'.</x:expect>
   </x:scenario>
</x:description>