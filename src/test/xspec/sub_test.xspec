<?xml version="1.0" encoding="UTF-8"?>
<x:description xmlns:x="http://www.jenitennison.com/xslt/xspec"
               xmlns:dtb="http://www.daisy.org/z3986/2005/dtbook/"
               xmlns:brl="http://www.daisy.org/z3986/2009/braille/"
               stylesheet="../../../xsl/dtbook2sbsform.xsl">
   <x:scenario label="sub als unterer Index">
      <x:param name="contraction" select="2"/>
      <x:context>
        <dtb:p xml:lang="de">
            <dtb:abbr>CO</dtb:abbr>
            <dtb:sub>2</dtb:sub> 
            <dtb:abbr>H</dtb:abbr>
            <dtb:sub>2</dtb:sub>
            <dtb:abbr>O</dtb:abbr> (<dtb:abbr>CO</dtb:abbr>
            <dtb:sub>2</dtb:sub>)
	</dtb:p>
      </x:context>
      <x:expect label="result">
y P
 &gt;CO1; &gt;H1;&gt;O =&gt;CO1;'= </x:expect>
   </x:scenario>
   <x:scenario label="sub mit select (Markierungen Chemie)">
      <x:param name="contraction" select="2"/>
      <x:context>
        <dtb:p xml:lang="de">
            <dtb:abbr>V</dtb:abbr>
            <dtb:sub>
               <brl:select>
                  <brl:when-braille>
                     <brl:literal>&lt;/</brl:literal>
                  </brl:when-braille>
                  <brl:otherwise>*</brl:otherwise>
               </brl:select>
            </dtb:sub>
	        </dtb:p>
      </x:context>
      <x:expect label="result">
y P
 &gt;V&lt;/ </x:expect>
   </x:scenario>
</x:description>