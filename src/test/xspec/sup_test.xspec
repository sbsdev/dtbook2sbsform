<?xml version="1.0" encoding="UTF-8"?>
<x:description xmlns:x="http://www.jenitennison.com/xslt/xspec"
               xmlns:dtb="http://www.daisy.org/z3986/2005/dtbook/"
               xmlns:brl="http://www.daisy.org/z3986/2009/braille/"
               stylesheet="../../../xsl/dtbook2sbsform.xsl">
   <x:scenario label="sup als Exponent">
      <x:param name="contraction" select="2"/>
      <x:context>
        <dtb:p xml:lang="de">2<dtb:sup>23</dtb:sup> x<dtb:sup>2</dtb:sup> x<dtb:sup>-2</dtb:sup> (2<dtb:sup>23</dtb:sup>) (x<dtb:sup>2</dtb:sup>) (x<dtb:sup>-2</dtb:sup>) </dtb:p>
      </x:context>
      <x:expect label="result">
y P
 #B\;: 'X\; 'X\-; =#B\;:'= ='X\;'= ='X\-;'= </x:expect>
   </x:scenario>
   <x:scenario label="sup als oberer Index">
      <x:param name="contraction" select="2"/>
      <x:context>
        <dtb:p xml:lang="de">
            <dtb:abbr>Cu</dtb:abbr>
            <dtb:sup>2+</dtb:sup>
         </dtb:p>
      </x:context>
      <x:expect label="result">
y P
 $CU\#B"+</x:expect>
   </x:scenario>
   <x:scenario label="sup mit select (hochgestellter Text)">
      <x:param name="contraction" select="2"/>
      <x:context>
        <dtb:p xml:lang="de">Kapital mal Zinssatz<dtb:sup>
               <brl:select>
                  <brl:when-braille> hoch Zeit</brl:when-braille>
                  <brl:otherwise>Zeit</brl:otherwise>
               </brl:select>
            </dtb:sup>
         </dtb:p>
      </x:context>
      <x:expect label="result">
y P
 KP MAL Z*SSZ HO4 ZT</x:expect>
   </x:scenario>
   <x:scenario label="sup mit select (Markierungen Chemie)">
      <x:param name="contraction" select="2"/>
      <x:context>
        <dtb:p xml:lang="de">
            <dtb:abbr>V</dtb:abbr>
            <dtb:sup>
               <brl:select>
                  <brl:when-braille>
                     <brl:literal>&gt;/</brl:literal>
                  </brl:when-braille>
                  <brl:otherwise>*</brl:otherwise>
               </brl:select>
            </dtb:sup>
         </dtb:p>
      </x:context>
      <x:expect label="result">
y P
 &gt;V&gt;/</x:expect>
   </x:scenario>
</x:description>