	        <stub xml:lang="de">
            <dtb:abbr>etc.</dtb:abbr>
         </stub>
      </x:context>
      <x:expect label="result">ET'C.</x:expect>
   </x:scenario>
   <x:scenario label="abbr a.">
      <x:param name="contraction" select="2"/>
      <x:context>
	        <stub xml:lang="de">
            <dtb:abbr>a.</dtb:abbr>
         </stub>
      </x:context>
      <x:expect label="result">A.</x:expect>
   </x:scenario>
   <x:scenario label="notag wrt.">
      <x:param name="contraction" select="2"/>
      <x:context>
	        <stub xml:lang="de">wrt.</stub>
      </x:context>
