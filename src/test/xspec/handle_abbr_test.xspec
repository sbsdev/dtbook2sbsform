<?xml version="1.0" encoding="UTF-8"?>
<x:description xmlns:x="http://www.jenitennison.com/xslt/xspec"
               xmlns:dtb="http://www.daisy.org/z3986/2005/dtbook/"
               xmlns:brl="http://www.daisy.org/z3986/2009/braille/"
               stylesheet="../../../xsl/dtbook2sbsform.xsl">
   <x:scenario label="abbr GmbH">
      <x:param name="contraction" select="2"/>
      <x:context>
	        <stub xml:lang="de">
            <dtb:abbr>GmbH</dtb:abbr>
         </stub>
      </x:context>
      <x:expect label="result">$GMB&gt;H</x:expect>
   </x:scenario>
   <x:scenario label="abbr USA">
      <x:param name="contraction" select="2"/>
      <x:context>
	        <stub xml:lang="de">
            <dtb:abbr>USA</dtb:abbr>
         </stub>
      </x:context>
      <x:expect label="result">&gt;USA</x:expect>
   </x:scenario>
   <x:scenario label="abbr cd">
      <x:param name="contraction" select="2"/>
      <x:context>
	        <stub xml:lang="de">
            <dtb:abbr>cd</dtb:abbr>
         </stub>
      </x:context>
      <x:expect label="result">'CD</x:expect>
   </x:scenario>
   <x:scenario label="abbr 3a">
      <x:param name="contraction" select="2"/>
      <x:context>
	        <stub xml:lang="de">3<dtb:abbr>a</dtb:abbr>
         </stub>
      </x:context>
      <x:expect label="result">#C'A</x:expect>
   </x:scenario>
   <x:scenario label="abbr Nr. 2">
      <x:param name="contraction" select="2"/>
      <x:context>
	        <stub xml:lang="de">
            <dtb:abbr>Nr. </dtb:abbr>2</stub>
      </x:context>
      <x:expect label="result">NR.#B</x:expect>
   </x:scenario>
   <x:scenario label="abbr z. B.">
