            <dtb:abbr>w. z. b. w.</dtb:abbr>
         </stub>
      </x:context>
      <x:expect label="result">W.Z.B.W.</x:expect>
   </x:scenario>
   <x:scenario label="abbr etc.">
      <x:param name="contraction" select="2"/>
