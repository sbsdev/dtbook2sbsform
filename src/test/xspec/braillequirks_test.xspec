<?xml version="1.0" encoding="UTF-8"?>
<x:description xmlns:x="http://www.jenitennison.com/xslt/xspec"
               xmlns:dtb="http://www.daisy.org/z3986/2005/dtbook/"
               xmlns:brl="http://www.daisy.org/z3986/2009/braille/"
               stylesheet="../../../xsl/dtbook2sbsform.xsl">
   <x:scenario label="test for !«">
      <x:context>
        <stub xml:lang="de">»Ich bin Bergfahrer!«</stub>
      </x:context>
      <x:expect label="result">(# B* B7G,R7+)</x:expect>
   </x:scenario>
   <x:scenario label="test for !">
      <x:context>
        <stub xml:lang="de">And we look farther on!</stub>
      </x:context>
      <x:expect label="result">+D WE LOOK F)TH7 ON+</x:expect>
   </x:scenario>
   <x:scenario label="test for Italy">
      <x:context>
        <stub xml:lang="de">
            <dtb:em>Italy</dtb:em> stands the other side!</stub>
      </x:context>
      <x:expect label="result">_IT:'Y ,]S THE OTH7 SIDE+</x:expect>
   </x:scenario>
   <x:scenario label="test for Italy">
      <x:context>
        <stub xml:lang="de">Forever intervene!</stub>
      </x:context>
      <x:expect label="result">F?EV7 *T7VCE+</x:expect>
   </x:scenario>
   <x:scenario label="&lt;em&gt; with previous text node ending in word">
      <x:param name="contraction" select="0"/>
      <x:context>
        <stub xml:lang="de">
	           <dtb:line>foo</dtb:line>
	           <dtb:line>
               <dtb:em>bar</dtb:em>
            </dtb:line>
	        </stub>
      </x:context>
      <x:expect label="result">
y LINEb
 FOO
y LINEe

y LINEb
 _BAR
y LINEe
</x:expect>
   </x:scenario>
   <x:scenario label="test for stick!!!«">
      <x:context>
        <stub xml:lang="de">»Sun-­block on a stick!!!«</stub>
      </x:context>
      <x:expect label="result">(S/-mBLO$ ON 'A ]I$+++)</x:expect>
   </x:scenario>
   <x:scenario label="test for AM">
      <x:context>
        <stub xml:lang="de">
            <dtb:abbr>AM</dtb:abbr>- und der <dtb:abbr>FM</dtb:abbr>-Skala,</stub>
      </x:context>
      <x:expect label="result">&gt;AM- U R &gt;FM-SK:A,</x:expect>
   </x:scenario>
   <x:scenario label="test for em with subelements (http://redmine.sbszh.ch/issues/show/816)">
      <x:param name="contraction" select="0"/>
      <x:context>
        <stub xml:lang="de">
            <dtb:em>
               <dtb:abbr>US</dtb:abbr>-Justizministerium</dtb:em>
        </stub>
      </x:context>
      <x:expect label="result">__&gt;US-JUSTIZMINISTERIUM'.</x:expect>
   </x:scenario>
   <x:scenario label="test for whitespace swallowed with adjacing inlines (http://redmine.sbszh.ch/issues/show/818)">
      <x:param name="contraction" select="2"/>
      <x:context>
        <stub xml:space="preserve" xml:lang="de"><dtb:em>Mein Mann.</dtb:em> <brl:v-form>Ihr</brl:v-form></stub>
      </x:context>
      <x:expect label="result">__M6 M+N.'. $I</x:expect>
   </x:scenario>
   <x:scenario label="Swallow white space whith embed new lines 1">
      <x:param name="contraction" select="2"/>
      <x:context>
        <stub xml:space="preserve" xml:lang="de">Gedanken – Strich      —</stub>
      </x:context>
      <x:expect label="result">&amp;DKC'- ]R#'-</x:expect>
   </x:scenario>
   <x:scenario label="Swallow white space whith embed new lines 2">
      <x:param name="contraction" select="2"/>
      <x:context>
        <stub xml:space="preserve" xml:lang="de">Gedanken
— Strich</stub>
      </x:context>
      <x:expect label="result">&amp;DKC'- ]R#</x:expect>
   </x:scenario>
   <x:scenario label="Swallow white space whith embed new lines 3">
      <x:param name="contraction" select="2"/>
      <x:context>
        <stub xml:space="preserve" xml:lang="de">Gedanken
  — Strich</stub>
      </x:context>
      <x:expect label="result">&amp;DKC'- ]R#</x:expect>
   </x:scenario>
   <x:scenario label="Swallow white space whith embed new lines 4">
      <x:param name="contraction" select="2"/>
      <x:context>
        <stub xml:space="preserve" xml:lang="de">Gedanken
                         —         Strich</stub>
      </x:context>
      <x:expect label="result">&amp;DKC'- ]R#</x:expect>
   </x:scenario>
   <x:scenario label="test 1 for brl:homograph (http://redmine.sbszh.ch/issues/show/925)">
      <x:param name="contraction" select="2"/>
      <x:context>
        <stub xml:lang="de">Iron <brl:homograph>M<brl:separator/>an</brl:homograph>
         </stub>
      </x:context>
      <x:expect label="result">IRON MAN</x:expect>
   </x:scenario>
   <x:scenario label="test 2 for brl:homograph (http://redmine.sbszh.ch/issues/show/925)">
      <x:param name="contraction" select="2"/>
      <x:context>
        <stub xml:lang="de">Iron <brl:homograph>Ma<brl:separator/>n</brl:homograph>
        </stub>
      </x:context>
      <x:expect label="result">IRON MAN</x:expect>
   </x:scenario>
   <x:scenario label="test 2 for Apostroph (pt. 6) vor Einzelbuchstaben mit Punkt innerhalb abbr (http://redmine.sbszh.ch/issues/show/927)">
      <x:param name="contraction" select="2"/>
      <x:context>
        <stub xml:lang="de">
            <dtb:abbr>A. B. D. E. F. G. H. I. J.</dtb:abbr>
        </stub>
      </x:context>
      <x:expect label="result">A.B.D.E.F.G.H.I.J.</x:expect>
   </x:scenario>
   <x:scenario label="&lt;em&gt; innerhalb Anführungszeichen liefern falsches Resultat (http://redmine.sbszh.ch/issues/show/1004)">
      <x:param name="contraction" select="2"/>
      <x:context>
        <stub xml:lang="de">»<dtb:em>Test</dtb:em>«</stub>
      </x:context>
      <x:expect label="result">(_TE])</x:expect>
   </x:scenario>
   <x:scenario label="Kursive/Fette Anführungszeichen bei brl:render=&#34;ignore&#34; I (http://redmine.sbszh.ch/issues/show/1006)">
      <x:param name="contraction" select="2"/>
      <x:context>
        <stub xml:lang="de">»<dtb:em brl:render="ignore">Test</dtb:em>«-Beispiel</stub>
      </x:context>
      <x:expect label="result">(TE])-,B,0</x:expect>
   </x:scenario>
   <x:scenario label="Kursive/Fette Anführungszeichen bei brl:render=&#34;ignore&#34; II (http://redmine.sbszh.ch/issues/show/1006)">
      <x:param name="contraction" select="2"/>
      <x:context>
        <stub xml:lang="de">
            <dtb:em brl:render="ignore">»Test«</dtb:em>-Beispiel</stub>
      </x:context>
      <x:expect label="result">(TE])-,B,0</x:expect>
   </x:scenario>
   <x:scenario label="Kursive/Fette Anführungszeichen bei brl:render=&#34;ignore&#34; III (http://redmine.sbszh.ch/issues/show/1006)">
      <x:param name="contraction" select="2"/>
      <x:context>
        <stub xml:lang="de">›<dtb:em brl:render="ignore">Test</dtb:em>‹-Beispiel</stub>
      </x:context>
      <x:expect label="result">'(TE]')-,B,0</x:expect>
   </x:scenario>
   <x:scenario label="Kursive/Fette Anführungszeichen bei brl:render=&#34;ignore&#34; IV (http://redmine.sbszh.ch/issues/show/1006)">
      <x:param name="contraction" select="2"/>
      <x:context>
        <stub xml:lang="de">
            <dtb:em brl:render="ignore">›Test‹</dtb:em>-Beispiel</stub>
      </x:context>
      <x:expect label="result">'(TE]')-,B,0</x:expect>
   </x:scenario>
   <x:scenario label="Single word mixed emphasis em before (http://redmine.sbszh.ch/issues/show/1007)">
      <x:param name="contraction" select="2"/>
      <x:context>
        <dtb:p xml:lang="de">
            <dtb:em>Menschen</dtb:em>versuch</dtb:p>
      </x:context>
      <x:expect label="result">
y P
 _MC5C'.V7SU4</x:expect>
   </x:scenario>
   <x:scenario label="Single word mixed emphasis em after">
      <x:param name="contraction" select="2"/>
      <x:context>
        <dtb:p xml:lang="de">Liebe<dtb:em>gang</dtb:em>
         </dtb:p>
      </x:context>
      <x:expect label="result">
y P
 L0;'_G+G</x:expect>
   </x:scenario>
   <x:scenario label="Single word mixed emphasis em inside">
      <x:param name="contraction" select="2"/>
      <x:context>
        <dtb:p xml:lang="de">Liebe<dtb:em>Menschen</dtb:em>versuch</dtb:p>
      </x:context>
      <x:expect label="result">
y P
 L0;'_MC5C'.V7SU4</x:expect>
   </x:scenario>
   <x:scenario label="Falsches Resultat bei gemischtem Bruch, wenn Zeilenumbruch vorkommt (http://redmine.sbszh.ch/issues/show/1065)">
      <x:param name="contraction" select="2"/>
      <x:context>
        <stub xml:space="preserve" xml:lang="de"><brl:num role="mixed">4
                1/2</brl:num></stub>
      </x:context>
      <x:expect label="result">#D#A;</x:expect>
   </x:scenario>
   <x:scenario label="Quotes w/o context 1">
      <x:param name="contraction" select="2"/>
      <x:context>
	        <stub xml:lang="de"> (»<dtb:abbr>Bsp.</dtb:abbr>!«</stub>
      </x:context>
      <x:expect label="result"> =(BSP.+)</x:expect>
   </x:scenario>
   <x:scenario label="Quotes with phone number">
      <x:param name="contraction" select="2"/>
      <x:context>
	        <dtb:p xml:lang="de">
            <brl:num role="phone">079 160 22 22</brl:num>«</dtb:p>
      </x:context>
      <x:expect label="result">
y P
 #JGI.AFJ.BB.BB')</x:expect>
   </x:scenario>
   <x:scenario label="Leading zeros in time indication Bug #1172, Bug #969, Bug ##1292">
      <x:param name="contraction" select="2"/>
      <x:context>
        <stub xml:lang="de">
            <brl:time value="11:05">11:05</brl:time>
         </stub>
      </x:context>
      <x:expect label="result">#AA':#JE</x:expect>
   </x:scenario>
   <x:scenario label="Many quoted paras 3">
      <x:param name="contraction" select="2"/>
      <x:context>
	        <stub xml:lang="de">
	           <dtb:p>»Okay. Aber ich würde es auch gar nicht wissen; bin erst ein paar Jahre in den <dtb:abbr>USA</dtb:abbr>.«</dtb:p>
	           <dtb:p>Sie hatte von Anfang an den Akzent bemerkt, der den Ausländer verriet, und fragte: »Na, und woher kommst du?«</dtb:p>
	        </stub>
      </x:context>
      <x:expect label="result">
y P
 (OKA'Y. A # 8E % \ GAR N W^C; B* 7] 6 PAAR JRE * E &gt;USA.)
y P
 S HE V +F+G + E AKZCT ;M7KT, R E 1SL@ND7 -R0T, U FRAG(: (NA, U WOH7 KX] DU?)</x:expect>
   </x:scenario>
</x:description>