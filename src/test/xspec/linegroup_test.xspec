<?xml version="1.0" encoding="UTF-8"?>
<x:description xmlns:x="http://www.jenitennison.com/xslt/xspec"
               xmlns:dtb="http://www.daisy.org/z3986/2005/dtbook/"
               xmlns:brl="http://www.daisy.org/z3986/2009/braille/"
               stylesheet="../../../xsl/dtbook2sbsform.xsl">
   <x:scenario label="Translation of linegroup">
      <x:context>
	        <dtb:linegroup xml:lang="de"/>
      </x:context>
      <x:expect label="result">
y LINEGRb
 
y LINEGRe
</x:expect>
   </x:scenario>
   <x:scenario label="Translation of linegroup with brl:class attr">
      <x:context>
	        <dtb:linegroup xml:lang="de" brl:class="foo"/>
      </x:context>
      <x:expect label="result">
y LINEGRb_foo
 
y LINEGRe_foo
</x:expect>
   </x:scenario>
   <x:scenario label="Translation of line">
      <x:context>
	        <dtb:line xml:lang="de"/>
      </x:context>
      <x:expect label="result">
y LINEb
 
y LINEe
</x:expect>
   </x:scenario>
   <x:scenario label="Translation of line with brl:class attr">
      <x:context>
	        <dtb:line xml:lang="de" brl:class="foo"/>
      </x:context>
      <x:expect label="result">
y LINEb_foo
 
y LINEe_foo
</x:expect>
   </x:scenario>
   <x:scenario label="linenum">
      <x:context>
	        <dtb:linenum xml:lang="de">Foo</dtb:linenum>
      </x:context>
      <x:expect label="result">FOO| </x:expect>
   </x:scenario>
   <x:scenario label="Line with linenum">
      <x:context>
	        <dtb:line xml:lang="de">
            <dtb:linenum>6</dtb:linenum>DAS HIER IST EIN KLEINER TEST. ES GEHT DARUM.</dtb:line>
      </x:context>
      <x:expect label="result">
y LINEb
 bF| D HR ] 6 KL67 TE]. % G=T D)UM.
y LINEe
</x:expect>
   </x:scenario>
   <x:scenario label="Line with large linenum">
      <x:context>
	        <dtb:line xml:lang="de">
            <dtb:linenum>36</dtb:linenum>DAS HIER IST EIN KLEINER TEST. ES GEHT DARUM.</dtb:line>
      </x:context>
      <x:expect label="result">
y LINEb
 CF| D HR ] 6 KL67 TE]. % G=T D)UM.
y LINEe
</x:expect>
   </x:scenario>
   <x:scenario label="Line with mixed lines">
      <x:context>
	        <dtb:line xml:lang="de">
            <dtb:linenum>6</dtb:linenum>DAS HIER IST EIN KLEINER TEST. ES GEHT DARUM.</dtb:line>
	        <dtb:line xml:lang="de">DAS HIER IST EIN KLEINER TEST. ES GEHT DARUM.</dtb:line>
	        <dtb:line xml:lang="de">
            <dtb:linenum>6</dtb:linenum>DAS HIER IST EIN KLEINER TEST. ES GEHT DARUM.</dtb:line>
      </x:context>
      <x:expect label="result">
y LINEb
 bF| D HR ] 6 KL67 TE]. % G=T D)UM.
y LINEe

y LINEb
 | D HR ] 6 KL67 TE]. % G=T D)UM.
y LINEe

y LINEb
 bF| D HR ] 6 KL67 TE]. % G=T D)UM.
y LINEe
</x:expect>
   </x:scenario>
   <x:scenario label="Poem with linenum">
      <x:context>
	        <dtb:poem xml:lang="de">
	           <dtb:line>
               <dtb:linenum>6</dtb:linenum>DAS HIER IST EIN KLEINER TEST. ES GEHT DARUM.</dtb:line>
	        </dtb:poem>
      </x:context>
      <x:expect label="result">
y POEM_LNb

y LINEb
 bF| D HR ] 6 KL67 TE]. % G=T D)UM.
y LINEe

y POEM_LNe
</x:expect>
   </x:scenario>
   <x:scenario label="Poem with mixed linenum">
      <x:context>
	        <dtb:poem xml:lang="de">
	           <dtb:line>
               <dtb:linenum>6</dtb:linenum>DAS HIER IST EIN KLEINER TEST. ES GEHT DARUM.</dtb:line>
	           <dtb:line>DAS HIER IST EIN KLEINER TEST. ES GEHT DARUM.</dtb:line>
	        </dtb:poem>
      </x:context>
      <x:expect label="result">
y POEM_LNb

y LINEb
 bF| D HR ] 6 KL67 TE]. % G=T D)UM.
y LINEe

y LINEb
 | D HR ] 6 KL67 TE]. % G=T D)UM.
y LINEe

y POEM_LNe
</x:expect>
   </x:scenario>
   <x:scenario label="Poem with mixed linenum inside linegroup">
      <x:context>
	        <dtb:poem xml:lang="de">
	           <dtb:linegroup>
	              <dtb:line>
                  <dtb:linenum>6</dtb:linenum>DAS HIER IST EIN KLEINER TEST. ES GEHT DARUM.</dtb:line>
	           </dtb:linegroup>
	           <dtb:linegroup>
	              <dtb:line>DAS HIER IST EIN KLEINER TEST. ES GEHT DARUM.</dtb:line>
	           </dtb:linegroup>
	        </dtb:poem>
      </x:context>
      <x:expect label="result">
y POEM_LNb

y LINEGR_LNb
 
y LINEb
 bF| D HR ] 6 KL67 TE]. % G=T D)UM.
y LINEe

y LINEGR_LNe

y LINEGR_LNb
 
y LINEb
 | D HR ] 6 KL67 TE]. % G=T D)UM.
y LINEe

y LINEGR_LNe

y POEM_LNe
</x:expect>
   </x:scenario>
</x:description>