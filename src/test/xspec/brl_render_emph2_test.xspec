<?xml version="1.0" encoding="UTF-8"?>
<x:description xmlns:x="http://www.jenitennison.com/xslt/xspec"
               xmlns:dtb="http://www.daisy.org/z3986/2005/dtbook/"
               xmlns:brl="http://www.daisy.org/z3986/2009/braille/"
               stylesheet="../../../xsl/dtbook2sbsform.xsl">
   <x:scenario label="Single word emphasis">
      <x:param name="contraction" select="2"/>
      <x:context>
        <dtb:em brl:render="emph2">foo</dtb:em>
      </x:context>
      <x:expect label="result">!_FOO</x:expect>
   </x:scenario>
   <x:scenario label="Multi word emphasis">
      <x:param name="contraction" select="2"/>
      <x:context>
        <dtb:em brl:render="emph2">foo bar</dtb:em>
      </x:context>
      <x:expect label="result">!!_FOO BAR!.</x:expect>
   </x:scenario>
   <x:scenario label="Single word mixed emphasis">
      <x:param name="contraction" select="2"/>
      <x:context>
        <stub xml:lang="de">
            <dtb:em brl:render="emph2">Foo</dtb:em>bar</stub>
      </x:context>
      <x:expect label="result">!_FOO!.BAR</x:expect>
   </x:scenario>
   <x:scenario label="Single word mixed emphasis">
      <x:param name="contraction" select="2"/>
      <x:context>
        <stub xml:lang="de">Foo<dtb:em brl:render="emph2">bar</dtb:em>
         </stub>
      </x:context>
      <x:expect label="result">FOO!_BAR</x:expect>
   </x:scenario>
   <x:scenario label="Single word mixed emphasis">
      <x:param name="contraction" select="1"/>
      <x:context>
        <stub xml:lang="de">Foo<dtb:em brl:render="emph2">bar</dtb:em>baz</stub>
      </x:context>
      <x:expect label="result">FOO!_BAR!.BAZ</x:expect>
   </x:scenario>
</x:description>