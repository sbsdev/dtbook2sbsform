<?xml version="1.0" encoding="UTF-8"?>
<x:description xmlns:x="http://www.jenitennison.com/xslt/xspec"
               xmlns:dtb="http://www.daisy.org/z3986/2005/dtbook/"
               xmlns:brl="http://www.daisy.org/z3986/2009/braille/"
               stylesheet="../../../xsl/dtbook2sbsform.xsl">
   <x:scenario label="brl:continuation attribute on &lt;em&gt;">
      <x:param name="contraction" select="2"/>
      <x:context>
        <stub xmlns:utfx="http://utfx.org/test-definition" xml:lang="de">
            <dtb:p>
               <dtb:em brl:continuation="em1 em2 em3">Bla bla bla.</dtb:em>
            </dtb:p>
            <dtb:p>
               <dtb:em id="em1">Bla bla bla.</dtb:em>
            </dtb:p>
            <dtb:p>
               <dtb:em id="em2">Bla bla bla.</dtb:em>
            </dtb:p>
            <dtb:p>
               <dtb:em id="em3">Bla bla bla.</dtb:em> Bla bla bla.</dtb:p>
            <dtb:p>Bla bla bla.</dtb:p>
            <dtb:p>
               <dtb:em>Bla bla bla.</dtb:em>
            </dtb:p>
        </stub>
      </x:context>
      <x:expect label="result">
y P
 __BLA BLA BLA.
y P
 BLA BLA BLA.
y P
 BLA BLA BLA.
y P
 BLA BLA BLA.'. BLA BLA BLA.
y P
 BLA BLA BLA.
y P
 __BLA BLA BLA.'.</x:expect>
   </x:scenario>
</x:description>