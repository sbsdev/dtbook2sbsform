   <x:scenario label="Römische Zahlen">
      <x:param name="contraction" select="2"/>
      <x:context>
        <dtb:p xmlns:utfx="http://utfx.org/test-definition" xml:lang="de">Henry <brl:num role="roman">IV</brl:num>.
          Auf Seite <brl:num role="roman">iii</brl:num> beginnt das Vorwort.</dtb:p>
      </x:context>
      <x:expect label="result">
y P
 HCR'Y &gt;IV. 1 S3( 'III ;G*NT D ,?W?T.</x:expect>
   </x:scenario>
