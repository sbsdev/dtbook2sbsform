<?xml version="1.0" encoding="UTF-8"?>
<x:description xmlns:x="http://www.jenitennison.com/xslt/xspec"
               xmlns:dtb="http://www.daisy.org/z3986/2005/dtbook/"
               xmlns:brl="http://www.daisy.org/z3986/2009/braille/"
               stylesheet="../../../xsl/dtbook2sbsform.xsl">
   <x:scenario label="brl:render=quote followed by colon">
      <x:param name="contraction" select="2"/>
      <x:context>
        <dtb:p xml:lang="de">bla <dtb:em brl:render="quote">ble ble 8</dtb:em>: blo</dtb:p>
      </x:context>
      <x:expect label="result">
y P
 BLA (BLE BLE #H'): BLO</x:expect>
   </x:scenario>
   <x:scenario label="brl:render=quote followed by exclamation mark">
      <x:param name="contraction" select="2"/>
      <x:context>
        <dtb:p xml:lang="de">bla <dtb:em brl:render="quote">ble ble 8</dtb:em>! blo</dtb:p>
      </x:context>
      <x:expect label="result">
y P
 BLA (BLE BLE #H')+ BLO</x:expect>
   </x:scenario>
   <x:scenario label="brl:render=quote followed by question mark">
      <x:param name="contraction" select="2"/>
      <x:context>
        <dtb:p xml:lang="de">bla <dtb:em brl:render="quote">ble ble 8</dtb:em>? blo</dtb:p>
      </x:context>
      <x:expect label="result">
y P
 BLA (BLE BLE #H')? BLO</x:expect>
   </x:scenario>
   <x:scenario label="brl:render=quote followed by semicolon">
      <x:param name="contraction" select="2"/>
      <x:context>
        <dtb:p xml:lang="de">bla <dtb:em brl:render="quote">ble ble 8</dtb:em>; blo</dtb:p>
      </x:context>
      <x:expect label="result">
y P
 BLA (BLE BLE #H'); BLO</x:expect>
   </x:scenario>
   <x:scenario label="brl:render=quote followed by closing parenthesis">
      <x:param name="contraction" select="2"/>
      <x:context>
        <dtb:p xml:lang="de">bla <dtb:em brl:render="quote">ble ble 8</dtb:em>) blo</dtb:p>
      </x:context>
      <x:expect label="result">
y P
 BLA (BLE BLE #H')= BLO</x:expect>
   </x:scenario>
   <x:scenario label="brl:render=quote followed by period">
      <x:param name="contraction" select="2"/>
      <x:context>
        <dtb:p xml:lang="de">bla <dtb:em brl:render="quote">ble ble 8</dtb:em>. blo</dtb:p>
      </x:context>
      <x:expect label="result">
y P
 BLA (BLE BLE #H'). BLO</x:expect>
   </x:scenario>
   <x:scenario label="brl:render=quote followed by comma">
      <x:param name="contraction" select="2"/>
      <x:context>
        <dtb:p xml:lang="de">bla <dtb:em brl:render="quote">ble ble 8</dtb:em>, blo</dtb:p>
      </x:context>
      <x:expect label="result">
y P
 BLA (BLE BLE #H'), BLO</x:expect>
   </x:scenario>
   <x:scenario label="brl:render=singlequote followed by colon">
      <x:param name="contraction" select="2"/>
      <x:context>
        <dtb:p xml:lang="de">bla <dtb:em brl:render="singlequote">ble ble 8</dtb:em>: blo</dtb:p>
      </x:context>
      <x:expect label="result">
y P
 BLA '(BLE BLE #H'): BLO</x:expect>
   </x:scenario>
   <x:scenario label="brl:render=singlequote followed by exclamation mark">
      <x:param name="contraction" select="2"/>
      <x:context>
        <dtb:p xml:lang="de">bla <dtb:em brl:render="singlequote">ble ble 8</dtb:em>! blo</dtb:p>
      </x:context>
      <x:expect label="result">
y P
 BLA '(BLE BLE #H')+ BLO</x:expect>
   </x:scenario>
   <x:scenario label="brl:render=singlequote followed by question mark">
      <x:param name="contraction" select="2"/>
      <x:context>
        <dtb:p xml:lang="de">bla <dtb:em brl:render="singlequote">ble ble 8</dtb:em>? blo</dtb:p>
      </x:context>
      <x:expect label="result">
y P
 BLA '(BLE BLE #H')? BLO</x:expect>
   </x:scenario>
   <x:scenario label="brl:render=singlequote followed by semicolon">
      <x:param name="contraction" select="2"/>
      <x:context>
        <dtb:p xml:lang="de">bla <dtb:em brl:render="singlequote">ble ble 8</dtb:em>; blo</dtb:p>
      </x:context>
      <x:expect label="result">
y P
 BLA '(BLE BLE #H'); BLO</x:expect>
   </x:scenario>
   <x:scenario label="brl:render=singlequote followed by closing parenthesis">
      <x:param name="contraction" select="2"/>
      <x:context>
        <dtb:p xml:lang="de">bla <dtb:em brl:render="singlequote">ble ble 8</dtb:em>) blo</dtb:p>
      </x:context>
      <x:expect label="result">
y P
 BLA '(BLE BLE #H')= BLO</x:expect>
   </x:scenario>
   <x:scenario label="brl:render=singlequote followed by period">
      <x:param name="contraction" select="2"/>
      <x:context>
        <dtb:p xml:lang="de">bla <dtb:em brl:render="singlequote">ble ble 8</dtb:em>. blo</dtb:p>
      </x:context>
      <x:expect label="result">
y P
 BLA '(BLE BLE #H'). BLO</x:expect>
   </x:scenario>
   <x:scenario label="brl:render=singlequote followed by comma">
      <x:param name="contraction" select="2"/>
      <x:context>
        <dtb:p xml:lang="de">bla <dtb:em brl:render="singlequote">ble ble 8</dtb:em>, blo</dtb:p>
      </x:context>
      <x:expect label="result">
y P
 BLA '(BLE BLE #H'), BLO</x:expect>
   </x:scenario>
</x:description>
