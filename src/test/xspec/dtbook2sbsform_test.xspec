   <x:scenario label="Span inside span 2">
      <x:context>
        <stub xml:lang="de">
            <dtb:p>
               <dtb:span brl:accents="reduced">René</dtb:span>
            </dtb:p>
            <dtb:p>
               <dtb:span brl:accents="reduced">René René</dtb:span>
            </dtb:p>
            <dtb:p>Kurz <dtb:span>╚</dtb:span>
               <dtb:span brl:grade="1" brl:accents="reduced">René René</dtb:span>
               <dtb:span>╝</dtb:span> René</dtb:p>
            <dtb:p>
               <dtb:span>╚</dtb:span>
               <dtb:span brl:grade="1">René <dtb:span brl:accents="reduced">René</dtb:span> René</dtb:span>
               <dtb:span>╝</dtb:span>
            </dtb:p>
        </stub>
      </x:context>
      <x:expect label="result">
y P
 RC"E
y P
 RC"E RC"E
y P
 KZ -.REN"E REN"E'. RC"%
y P
 -.REN"% REN"E REN"%'.</x:expect>
   </x:scenario>
   <x:scenario label="Span inside em">
