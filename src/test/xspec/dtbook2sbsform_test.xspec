            <dtb:abbr>ISBN</dtb:abbr> 
            <brl:num role="isbn">978-3-86971-001-X</brl:num> 
            <dtb:abbr>ISBN</dtb:abbr> 
            <brl:num role="isbn">978 3 86971 001 3</brl:num>
         </dtb:p>
      </x:context>
      <x:expect label="result">
y P
 &gt;ISBN #IGH.C.HFIGA.JJA.C &gt;ISBN #IGH.C.HFIGA.JJA-&gt;X &gt;ISBN #IGH.C.HFIGA.JJA.C</x:expect>
   </x:scenario>
