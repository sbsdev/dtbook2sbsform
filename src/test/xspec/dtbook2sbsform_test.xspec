            <dtb:em>Wort</dtb:em>, <dtb:strong>Wort</dtb:strong>, <brl:emph>Wort</brl:emph>. <dtb:em>Zwei Wörter</dtb:em>, <dtb:strong>eins/zwei</dtb:strong>, <brl:emph>eins-­zwei</brl:emph>.</stub>
      </x:context>
      <x:expect label="result">_W?T, _W?T, _W?T. __ZW3 W9RT7'., __6S!,ZW3'., __6S-mZW3'..</x:expect>
   </x:scenario>
   <x:scenario label="Separator ist keine Wortgrenze">
