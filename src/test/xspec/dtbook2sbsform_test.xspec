      </stub>
    </x:context>
    <x:expect label="word caps sign once, no per-letter caps signs">
 >USA</x:expect>
  </x:scenario>

  <x:scenario label="abbr mixed case capitalization not doubled when enable_capitalization is true http://redmine.sbszh.ch/issues/2685">
