<?xml version="1.0" encoding="UTF-8"?>
<x:description xmlns:x="http://www.jenitennison.com/xslt/xspec"
               xmlns:dtb="http://www.daisy.org/z3986/2005/dtbook/"
               xmlns:brl="http://www.daisy.org/z3986/2009/braille/"
               stylesheet="../../../xsl/handle-downgrading.xsl">
   <x:scenario label="Downgrading">
      <x:param name="contraction" select="2"/>
      <x:context>
        <stub xml:lang="de">
            <dtb:p>Kurzschrift schrift schrift <dtb:span brl:grade="1">Vollschrift</dtb:span> kurz kurz kurz</dtb:p>
            <dtb:p>Kurzschrift schrift schrift <dtb:span brl:grade="0">Basisschrift</dtb:span> kurz kurz kurz</dtb:p>
            <dtb:p>Kurzschrift schrift schrift <dtb:span brl:grade="1">Vollschrift schrift schrift</dtb:span> kurz kurz kurz</dtb:p>
            <dtb:p>Kurzschrift schrift schrift <dtb:span brl:grade="0">Basisschrift schrift schrift</dtb:span> kurz kurz kurz</dtb:p>
            <dtb:p>Kurzschrift schrift schrift <dtb:span brl:grade="1">Vollschrift/Vollschrift</dtb:span> kurz kurz kurz</dtb:p>
            <dtb:p>Kurzschrift schrift schrift <dtb:span brl:grade="0">Basisschrift/Basisschrift</dtb:span> kurz kurz kurz</dtb:p>
            <dtb:p>Kurzschrift schrift schrift <dtb:span brl:grade="1">Vollschrift-­Vollschrift</dtb:span> kurz kurz kurz</dtb:p>
            <dtb:p>Kurzschrift schrift schrift <dtb:span brl:grade="0">Basisschrift-­Basisschrift</dtb:span> kurz kurz kurz</dtb:p>
        </stub>
      </x:context>
      <x:expect label="result">
        <stub xml:lang="de">
            <dtb:p>Kurzschrift schrift schrift <dtb:span>╙</dtb:span>
               <dtb:span brl:grade="1">Vollschrift</dtb:span> kurz kurz kurz</dtb:p>
            <dtb:p>Kurzschrift schrift schrift <dtb:span>╙</dtb:span>
               <dtb:span brl:grade="0">Basisschrift</dtb:span> kurz kurz kurz</dtb:p>
            <dtb:p>Kurzschrift schrift schrift <dtb:span>╚</dtb:span>
               <dtb:span brl:grade="1">Vollschrift schrift schrift</dtb:span>
               <dtb:span>╝</dtb:span> kurz kurz kurz</dtb:p>
            <dtb:p>Kurzschrift schrift schrift <dtb:span>╚</dtb:span>
               <dtb:span brl:grade="0">Basisschrift schrift schrift</dtb:span>
               <dtb:span>╝</dtb:span> kurz kurz kurz</dtb:p>
            <dtb:p>Kurzschrift schrift schrift <dtb:span>╚</dtb:span>
               <dtb:span brl:grade="1">Vollschrift/Vollschrift</dtb:span>
               <dtb:span>╝</dtb:span> kurz kurz kurz</dtb:p>
            <dtb:p>Kurzschrift schrift schrift <dtb:span>╚</dtb:span>
               <dtb:span brl:grade="0">Basisschrift/Basisschrift</dtb:span>
               <dtb:span>╝</dtb:span> kurz kurz kurz</dtb:p>
            <dtb:p>Kurzschrift schrift schrift <dtb:span>╚</dtb:span>
               <dtb:span brl:grade="1">Vollschrift-­Vollschrift</dtb:span>
               <dtb:span>╝</dtb:span> kurz kurz kurz</dtb:p>
            <dtb:p>Kurzschrift schrift schrift <dtb:span>╚</dtb:span>
               <dtb:span brl:grade="0">Basisschrift-­Basisschrift</dtb:span>
               <dtb:span>╝</dtb:span> kurz kurz kurz</dtb:p>
        </stub>
      </x:expect>
   </x:scenario>
   <x:scenario label="Downgrading with nbsp">
      <x:param name="contraction" select="2"/>
      <x:context>
        <stub xml:lang="de">
	           <dtb:p>bla <dtb:span brl:grade="0">H A L L O</dtb:span> bla</dtb:p>
	           <dtb:p>bla <dtb:span brl:grade="0">H A L L O</dtb:span> bla</dtb:p>
        </stub>
      </x:context>
      <x:expect label="result">
        <stub xml:lang="de">
	           <dtb:p>bla <dtb:span>╚</dtb:span>
               <dtb:span brl:grade="0">H A L L O</dtb:span>
               <dtb:span>╝</dtb:span> bla</dtb:p>
	           <dtb:p>bla <dtb:span>╚</dtb:span>
               <dtb:span brl:grade="0">H A L L O</dtb:span>
               <dtb:span>╝</dtb:span> bla</dtb:p>
        </stub>
      </x:expect>
   </x:scenario>
   <x:scenario label="Downgrading from grade 1 to grade 0">
      <x:param name="contraction" select="1"/>
      <x:context>
        <stub xml:lang="de">
            <dtb:p>Vollschrift schrift schrift <dtb:span brl:grade="1">Basisschrift/Basisschrift</dtb:span> voll voll voll</dtb:p>
        </stub>
      </x:context>
      <x:expect label="result">
        <stub xml:lang="de">
            <dtb:p>Vollschrift schrift schrift <dtb:span brl:grade="1">Basisschrift/Basisschrift</dtb:span> voll voll voll</dtb:p>
        </stub>
      </x:expect>
   </x:scenario>
   <x:scenario label="Span inside span 2">
      <x:param name="contraction" select="2"/>
      <x:context>
        <stub xml:lang="de">
            <dtb:p>
               <dtb:span brl:accents="reduced">René</dtb:span>
            </dtb:p>
            <dtb:p>
               <dtb:span brl:accents="reduced">René René</dtb:span>
            </dtb:p>
            <dtb:p>Kurz <dtb:span brl:grade="1" brl:accents="reduced">René René</dtb:span> René</dtb:p>
            <dtb:p>
               <dtb:span brl:grade="1">René <dtb:span brl:accents="reduced">René</dtb:span> René</dtb:span>
            </dtb:p>
        </stub>
      </x:context>
      <x:expect label="result">
        <stub xml:lang="de">
            <dtb:p>
               <dtb:span brl:accents="reduced">René</dtb:span>
            </dtb:p>
            <dtb:p>
               <dtb:span brl:accents="reduced">René René</dtb:span>
            </dtb:p>
            <dtb:p>Kurz <dtb:span>╚</dtb:span>
               <dtb:span brl:grade="1" brl:accents="reduced">René René</dtb:span>
               <dtb:span>╝</dtb:span> René</dtb:p>
            <dtb:p>
               <dtb:span>╚</dtb:span>
               <dtb:span brl:grade="1">René <dtb:span brl:accents="reduced">René</dtb:span> René</dtb:span>
               <dtb:span>╝</dtb:span>
            </dtb:p>
        </stub>
      </x:expect>
   </x:scenario>
   <x:scenario label="pagenum as first child of level should not swallow grade-change announcement http://redmine.sbszh.ch/issues/3048">
      <x:param name="contraction" select="2"/>
      <x:context>
        <stub xml:lang="de">
          <dtb:level2 xml:lang="gsw">
            <dtb:pagenum>106</dtb:pagenum>
            <dtb:h2>Ds Vrinelis Gärtli</dtb:h2>
          </dtb:level2>
        </stub>
      </x:context>
      <x:expect label="╚ placed before heading text, not inside pagenum">
        <stub xml:lang="de">
          <dtb:level2 xml:lang="gsw">
            <dtb:pagenum>106</dtb:pagenum>
            <dtb:h2><dtb:span>╚</dtb:span>Ds Vrinelis Gärtli<dtb:span>╝</dtb:span></dtb:h2>
          </dtb:level2>
        </stub>
      </x:expect>
   </x:scenario>
   <x:scenario label="pagenum as first and last child of poem should not suppress grade-change announcements http://redmine.sbszh.ch/issues/2744">
      <x:param name="contraction" select="2"/>
      <x:context>
        <stub xml:lang="de">
          <dtb:poem xml:lang="en">
            <dtb:pagenum id="page-101" page="normal">101</dtb:pagenum>
            <dtb:line>bla bla</dtb:line>
            <dtb:line>bla bla</dtb:line>
            <dtb:pagenum id="page-102" page="normal">102</dtb:pagenum>
          </dtb:poem>
        </stub>
      </x:context>
      <x:expect label="╚ before first line, ╝ after last line, pagenums untouched">
        <stub xml:lang="de">
          <dtb:poem xml:lang="en">
            <dtb:pagenum id="page-101" page="normal">101</dtb:pagenum>
            <dtb:line><dtb:span>╚</dtb:span>bla bla</dtb:line>
            <dtb:line>bla bla<dtb:span>╝</dtb:span></dtb:line>
            <dtb:pagenum id="page-102" page="normal">102</dtb:pagenum>
          </dtb:poem>
        </stub>
      </x:expect>
   </x:scenario>
   <x:scenario label="Language change">
      <x:param name="contraction" select="2"/>
      <x:context>
        <stub xml:lang="de">
            <dtb:p>Jetzt folgt ein Gedicht:</dtb:p>
            <dtb:poem xml:lang="en">
               <dtb:linegroup>
                  <dtb:line>If you want to get a favour done</dtb:line>
                  <dtb:line>By some obliging friend,</dtb:line>
                  <dtb:line>And want a promise, safe and sure,</dtb:line>
                  <dtb:line>On which you may depend,</dtb:line>
                  <dtb:line>Don't go to him who always has</dtb:line>
                  <dtb:line>Much leisure time to plan,</dtb:line>
                  <dtb:line>If you want your favour done,</dtb:line>
                  <dtb:line>Just ask the busy man.</dtb:line>
               </dtb:linegroup>
            </dtb:poem>
        </stub>
      </x:context>
      <x:expect label="result">
        <stub xml:lang="de">
            <dtb:p>Jetzt folgt ein Gedicht:</dtb:p>
            <dtb:poem xml:lang="en">
               <dtb:linegroup>
                  <dtb:line>
                     <dtb:span>╚</dtb:span>If you want to get a favour done</dtb:line>
                  <dtb:line>By some obliging friend,</dtb:line>
                  <dtb:line>And want a promise, safe and sure,</dtb:line>
                  <dtb:line>On which you may depend,</dtb:line>
                  <dtb:line>Don't go to him who always has</dtb:line>
                  <dtb:line>Much leisure time to plan,</dtb:line>
                  <dtb:line>If you want your favour done,</dtb:line>
                  <dtb:line>Just ask the busy man.<dtb:span>╝</dtb:span>
                  </dtb:line>
               </dtb:linegroup>
            </dtb:poem>
        </stub>
      </x:expect>
   </x:scenario>
   <x:scenario label="Language change (but contraction for whole document is '0')">
      <x:param name="contraction" select="0"/>
      <x:context>
        <stub xml:lang="de">
            <dtb:p>Jetzt folgt ein Gedicht:</dtb:p>
            <dtb:poem xml:lang="en">
               <dtb:linegroup>
                  <dtb:line>If you want to get a favour done</dtb:line>
                  <dtb:line>By some obliging friend,</dtb:line>
                  <dtb:line>And want a promise, safe and sure,</dtb:line>
                  <dtb:line>On which you may depend,</dtb:line>
                  <dtb:line>Don't go to him who always has</dtb:line>
                  <dtb:line>Much leisure time to plan,</dtb:line>
                  <dtb:line>If you want your favour done,</dtb:line>
                  <dtb:line>Just ask the busy man.</dtb:line>
               </dtb:linegroup>
            </dtb:poem>
        </stub>
      </x:context>
      <x:expect label="result">
        <stub xml:lang="de">
            <dtb:p>Jetzt folgt ein Gedicht:</dtb:p>
            <dtb:poem xml:lang="en">
               <dtb:linegroup>
                  <dtb:line>If you want to get a favour done</dtb:line>
                  <dtb:line>By some obliging friend,</dtb:line>
                  <dtb:line>And want a promise, safe and sure,</dtb:line>
                  <dtb:line>On which you may depend,</dtb:line>
                  <dtb:line>Don't go to him who always has</dtb:line>
                  <dtb:line>Much leisure time to plan,</dtb:line>
                  <dtb:line>If you want your favour done,</dtb:line>
                  <dtb:line>Just ask the busy man.</dtb:line>
               </dtb:linegroup>
            </dtb:poem>
        </stub>
      </x:expect>
   </x:scenario>
</x:description>